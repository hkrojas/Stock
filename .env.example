# FastAPI backend environment template

# Required in non-local environments
SECRET_KEY=replace-with-a-long-random-secret
DATABASE_URL=sqlite:///./stock_local.db
REDIS_URL=redis://localhost:6379/0

# Comma-separated list of allowed origins for the SPA/mobile gateways.
# Example:
# BACKEND_CORS_ORIGINS=http://localhost:5173,https://stock.example.com
BACKEND_CORS_ORIGINS=http://localhost:5173

# Set to true only for local/demo scenarios if explicit seeding scripts are used.
ENABLE_DEMO_SEED=false
APP_ENV=local
